{
  "name": "Hybrid Console Dev (VNC + FFmpeg Audio)",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-ubuntu-22.04",
  "forwardPorts": [6080, 8081],
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vncpassword"
    }
  },
  "containerEnv": {
    "DISPLAY": ":1"
  },
  // FFmpeg와 시뮬레이션에 필요한 라이브러리를 한 번에 설치
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y verilator libsdl2-dev libsdl2-image-dev libsdl2-ttf-dev ffmpeg build-essential",
  "customizations": {
    "vscode": {
      "extensions": [
        "mshr-h.VerilogHDL",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack"
      ]
    }
  },
  "remoteUser": "vscode"
}
